#![deny(unused_imports)]

pub(crate) use __cargo_equip::prelude::*;

use maplit::{btreemap, btreeset, convert_args, hashmap, hashset};

fn main() {
    let _ = btreemap!(() => ());
    let _ = btreeset!(());
    let _ = hashmap!(() => ());
    let _ = hashset!(());
    assert_eq!(hashset!(2), convert_args!(keys = |x| x + 1, hashset!(1)));
}

